{
  "type": "module",
  "name": "array-utils-ts",
  "version": "1.1.0",
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && pkgroll --minify && ls -lah dist",
    "test": "tsx --test --test-reporter=dot src/main.test.ts",
    "test-cov": "tsx --experimental-test-coverage --test src/main.test.ts",
    "test-watch": "watchexec -e ts 'clear && npm test'",
    "format": "prettier --write --log-level warn .",
    "lint": "tsc --noEmit && prettier --check .",
    "ci": "npm run lint && npm run test-cov && npm run build"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "pkgroll": "2.27.0",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "author": "vladkens <v.pronsky@gmail.com>",
  "repository": "vladkens/array-utils-ts",
  "description": "Zero-dependency TypeScript library for immutable array operations: filter nullables, upsert/toggle by key, deduplicate, enumerate, and more.",
  "keywords": [
    "array",
    "collections",
    "deduplicate",
    "enumerate",
    "filter",
    "functional",
    "generics",
    "immutable",
    "lodash",
    "nullable",
    "ramda",
    "react",
    "state-management",
    "stdlib",
    "toggle",
    "ts",
    "types",
    "typescript",
    "underscore",
    "unique",
    "upsert",
    "util",
    "utilities",
    "utility",
    "utils",
    "zero-dependency"
  ],
  "files": [
    "dist"
  ],
  "types": "./dist/main.d.cts",
  "exports": {
    "require": {
      "types": "./dist/main.d.cts",
      "default": "./dist/main.cjs"
    },
    "import": {
      "types": "./dist/main.d.mts",
      "default": "./dist/main.mjs"
    }
  }
}
